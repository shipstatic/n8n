{
	"name": "n8n-nodes-shipstatic",
	"version": "0.1.0",
	"description": "n8n community node for Shipstatic — deploy and manage static sites",
	"keywords": ["n8n-community-node-package", "n8n", "ship", "shipstatic", "static-hosting", "deploy"],
	"license": "MIT",
	"author": {
		"name": "ShipStatic",
		"email": "hello@shipstatic.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/shipstatic/node.git"
	},
	"main": "dist/nodes/Shipstatic/Shipstatic.node.js",
	"scripts": {
		"dev": "n8n-node dev",
		"build": "n8n-node build",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"release": "release-it"
	},
	"files": ["dist"],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": ["dist/credentials/ShipstaticApi.credentials.js"],
		"nodes": ["dist/nodes/Shipstatic/Shipstatic.node.js"]
	},
	"dependencies": {
		"@shipstatic/ship": "^0.7.2"
	},
	"devDependencies": {
		"@n8n/node-cli": "latest",
		"eslint": "^9.0.0",
		"prettier": "^3.0.0",
		"release-it": "^18.0.0",
		"typescript": "^5.0.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"engines": {
		"node": ">=22.16"
	}
}
