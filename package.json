{
	"name": "n8n-nodes-shipstatic",
	"version": "0.2.1",
	"description": "Free, no account needed — deploy static websites, landing pages, and prototypes instantly from n8n workflows",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"shipstatic",
		"deploy",
		"hosting",
		"website",
		"static-site",
		"static-hosting",
		"web-hosting",
		"vibe-coding",
		"ai"
	],
	"license": "MIT",
	"author": {
		"name": "ShipStatic",
		"email": "hello@shipstatic.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/shipstatic/node.git"
	},
	"main": "dist/nodes/Shipstatic/Shipstatic.node.js",
	"scripts": {
		"dev": "n8n-node dev",
		"build": "n8n-node build",
		"test": "vitest",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"release": "release-it"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/ShipstaticApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Shipstatic/Shipstatic.node.js"
		]
	},
	"dependencies": {
		"@shipstatic/ship": "^0.8.6"
	},
	"devDependencies": {
		"@n8n/node-cli": "latest",
		"eslint": "^9.0.0",
		"prettier": "^3.0.0",
		"release-it": "^18.0.0",
		"typescript": "^5.0.0",
		"vitest": "^4.1.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"engines": {
		"node": ">=22.16"
	}
}
